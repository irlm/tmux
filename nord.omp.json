{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "#81a1c1",
          "template": "{{ .UserName }}@{{ .HostName | splitList \".\" | first }}"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#4c566a",
          "template": " \u203a "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#88c0d0",
          "options": {
            "folder_separator_icon": " \u203a ",
            "max_depth": 2,
            "style": "agnoster_short"
          },
          "template": "{{ .Path }}"
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#a3be8c",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ebcb8b{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#d08770{{ end }}",
            "{{ if gt .Behind 0 }}#bf616a{{ end }}"
          ],
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " ({{ .HEAD }}{{ if .Staging.Changed }} +{{ .Staging.String }}{{ end }}{{ if .Working.Changed }} !{{ .Working.String }}{{ end }}{{ if gt .Ahead 0 }} \u2191{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} \u2193{{ .Behind }}{{ end }})"
        },
        {
          "type": "node",
          "style": "plain",
          "foreground": "#5e81ac",
          "template": " node:{{ .Full }}"
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "#5e81ac",
          "template": " py:{{ if .Venv }}({{ .Venv }}) {{ end }}{{ .Full }}"
        },
        {
          "type": "rust",
          "style": "plain",
          "foreground": "#5e81ac",
          "template": " rs:{{ .Full }}"
        },
        {
          "type": "go",
          "style": "plain",
          "foreground": "#5e81ac",
          "template": " go:{{ .Full }}"
        },
        {
          "type": "java",
          "style": "plain",
          "foreground": "#5e81ac",
          "template": " java:{{ .Full }}"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#a3be8c",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#bf616a{{ end }}"
          ],
          "template": " \u276f "
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#d08770",
          "options": {
            "threshold": 2000
          },
          "template": "{{ .FormattedMs }}"
        }
      ]
    }
  ]
}
